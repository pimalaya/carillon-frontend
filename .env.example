# carillon-admin environment. Copy to `.env.local` and adjust. Documents the
# knobs only — never commit real secrets.

# ── Drive a real carillon-server (the point of this dashboard) ────────────────
# Point at a running server and mocks turn off automatically. The server must
# allow this origin — set it in the server's config (carillon.toml):
#   [api]
#   listen = "127.0.0.1:3000"
#   cors_allow_origin = "http://localhost:5173"
# then here:
#   VITE_API_BASE_URL=http://127.0.0.1:3000
#
# Empty = same-origin (the self-host embed case, where the daemon serves this
# build and no CORS is needed).
VITE_API_BASE_URL=

# ── Mock mode (offline UI development) ────────────────────────────────────────
# Left unset, mocks are ON in dev when no API base is set, and OFF as soon as
# VITE_API_BASE_URL points somewhere. Force it either way here:
#   true  -> in-browser MSW mocks + a synthetic SSE stream
#   false -> talk to VITE_API_BASE_URL for real
# One-time setup for the mock service worker:  npm run mocks:init
# VITE_ENABLE_MOCKS=true
